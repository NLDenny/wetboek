---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<details class="callout" open>
  <summary class="callout__title">{title}</summary>
  <div class="callout__body">
    <slot />
  </div>
</details>

<style>
  .callout {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold);
    border-radius: 4px;
    background: var(--color-bg-alt);
    margin: 1.25rem 0;
    padding: 0.75rem 1rem;
  }

  .callout__title {
    font-weight: 700;
    cursor: pointer;
  }

  .callout__body {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .callout__body :global(p:first-child) {
    margin-top: 0;
  }

  .callout__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout__body :global(ul) {
    flex: 1 1 12rem;
    margin: 0;
  }

  .callout__body :global(img) {
    flex-shrink: 0;
    border-radius: 4px;
  }
</style>

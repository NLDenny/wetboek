---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="callout">
  <details class="callout__main" open>
    <summary class="callout__title">{title}</summary>
    <div class="callout__body">
      <slot />
    </div>
  </details>
  <div class="callout__aside">
    <slot name="aside" />
  </div>
</div>

<style>
  /* Chromium quirk: a <details> element used directly as a CSS grid
     container with a row-spanning grid-template-area computes one row
     as 0px tall (reproduced in isolation, unrelated to Astro/MDX) --
     so <details> stays a plain block here, and a wrapping <div> is the
     actual grid container instead. */
  .callout {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    column-gap: 1.25rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold);
    border-radius: 4px;
    background: var(--color-bg-alt);
    margin: 1.25rem 0;
    padding: 0.75rem 1rem;
  }

  .callout__main {
    min-width: 0;
  }

  .callout__title {
    font-weight: 700;
    cursor: pointer;
  }

  .callout__body {
    margin-top: 0.5rem;
  }

  .callout__body :global(p:first-child) {
    margin-top: 0;
  }

  .callout__body :global(p:last-child) {
    margin-bottom: 0;
  }

  .callout__body :global(ul) {
    margin: 0;
  }

  .callout__aside:empty {
    display: none;
  }

  .callout__aside :global(img) {
    display: block;
    border-radius: 4px;
  }
</style>

---
import { getImage } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import ArticlePreview from '../components/ArticlePreview.astro';
import dojSeal from '../assets/img/doj-seal.png';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Wetboek van Los Santos — Department of Justice' } = Astro.props;
const currentPath = Astro.url.pathname;
const pageTitle = `${title} | Los Santos`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
// doj-seal.png is square (1200x1200), not the "ideal" 1.91:1 OG ratio, but
// it's the only existing branded high-res asset -- Discord (the primary
// share target for this FiveM RP community) scales square images fine
// without cropping, so reusing it avoids needing a separately authored
// landscape asset.
const ogImage = await getImage({ src: dojSeal, width: 1200, height: 1200, format: 'png' });
const ogImageUrl = new URL(ogImage.src, Astro.site).toString();
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Wetboek van Los Santos" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script is:inline>
      (function () {
        var stored = localStorage.getItem('wetboek-theme');
        var theme = stored === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <AnnouncementBanner />
    <Header />
    <div class="shell">
      <aside class="shell__sidebar">
        <Sidebar currentPath={currentPath} />
      </aside>
      <main class="shell__content">
        <slot />
      </main>
    </div>
    <Footer />
    <ArticlePreview />
  </body>
</html>

<style>
  .shell {
    flex: 1 0 auto;
    min-width: 0;
    width: 100%;
    max-width: 76rem;
    margin: 0 auto;
    padding: 2rem 1.25rem;
    display: grid;
    grid-template-columns: 16rem 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .shell__sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--banner-offset) + 1.5rem);
  }

  /* min-width: 0 breaks the automatic-minimum-size chain: a wide inline
     image deep inside .shell__content (e.g. the home page's photo) would
     otherwise force this grid item -- and everything above it up to
     <body> -- wider than the viewport, even though the image itself has
     max-width: 100% (that CSS rule doesn't affect min-content sizing for
     flex/grid items, only the final rendered size). Same root cause as
     the header search box fix, just one layer further up the tree. */
  .shell__content {
    min-width: 0;
  }

  @media (max-width: 60rem) {
    .shell {
      grid-template-columns: 1fr;
    }

    .shell__sidebar {
      display: none;
      position: fixed;
      top: calc(var(--header-height) + var(--banner-offset));
      left: 0;
      bottom: 0;
      z-index: 15;
      width: 16rem;
      max-width: 85vw;
      overflow-y: auto;
      background: var(--color-bg);
      padding: 1.25rem;
      box-shadow: 4px 0 16px rgba(0, 0, 0, 0.25);
    }

    :global(body.nav-open) .shell__sidebar {
      display: block;
    }
  }
</style>

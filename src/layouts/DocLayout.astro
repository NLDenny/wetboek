---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings: Heading[];
}

const { title, description, headings } = Astro.props;
const hasToc = headings.some((h) => h.depth >= 2 && h.depth <= 4);
---

<BaseLayout title={title} description={description}>
  <div class:list={['doc', { 'doc--no-toc': !hasToc }]}>
    <article class="doc__article">
      <h1>{title}</h1>
      <slot />
    </article>
    {hasToc && (
      <aside class="doc__toc">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .doc {
    display: grid;
    grid-template-columns: 1fr 14rem;
    gap: 2.5rem;
    align-items: start;
  }

  .doc--no-toc {
    grid-template-columns: 1fr;
  }

  .doc__toc {
    position: sticky;
    top: calc(var(--header-height) + 1.5rem);
  }

  .doc__article :global(h5) {
    color: var(--color-link);
    font-size: 1.05rem;
    margin-top: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .doc__article :global(h3),
  .doc__article :global(h4) {
    margin-top: 2.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.35rem;
  }

  .doc__article :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  .doc__article :global(th),
  .doc__article :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }

  .doc__article :global(th) {
    background: var(--color-bg-alt);
  }

  @media (max-width: 60rem) {
    .doc {
      grid-template-columns: 1fr;
    }

    .doc__toc {
      position: static;
    }
  }
</style>

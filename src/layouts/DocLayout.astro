---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings: Heading[];
  abbr?: string;
}

const { title, description, headings, abbr } = Astro.props;
const hasToc = headings.some((h) => h.depth >= 2 && h.depth <= 4);
---

<BaseLayout title={title} description={description}>
  <div class:list={['doc', { 'doc--no-toc': !hasToc }]}>
    <article class="doc__article">
      <h1>{title}</h1>
      <slot />
    </article>
    {hasToc && (
      <aside class="doc__toc">
        <TableOfContents headings={headings} />
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .doc {
    display: grid;
    grid-template-columns: 1fr 14rem;
    gap: 2.5rem;
    align-items: start;
  }

  .doc--no-toc {
    grid-template-columns: 1fr;
  }

  .doc__article {
    /* Without this, a wide table's min-content (even with the
       overflow-x: auto below) still counts toward this grid item's
       automatic minimum size, forcing the whole page wider than the
       viewport instead of letting the table scroll within its own box.
       Same root cause as .shell/.shell__content in BaseLayout.astro. */
    min-width: 0;
  }

  .doc__toc {
    position: sticky;
    top: calc(var(--header-height) + var(--banner-offset) + 1.5rem);
  }

  .doc__article :global(h5) {
    color: var(--color-link);
    font-size: 1.05rem;
    margin-top: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .doc__article :global(.permalink-btn) {
    position: relative;
    top: 0.15em;
    display: inline-flex;
    margin-left: 0.4rem;
    padding: 0.1rem;
    border: none;
    background: none;
    color: var(--color-text-muted);
    cursor: pointer;
    opacity: 0;
  }

  .doc__article :global(.permalink-btn svg) {
    width: 0.85em;
    height: 0.85em;
  }

  .doc__article :global(h5:hover .permalink-btn),
  .doc__article :global(.permalink-btn:focus-visible) {
    opacity: 1;
  }

  .doc__article :global(.permalink-btn:hover) {
    color: var(--color-link);
  }

  .doc__article :global(.permalink-btn.is-copied) {
    opacity: 1;
    color: var(--color-link);
  }

  .doc__article :global(.permalink-btn.is-copied)::after {
    content: 'Link gekopieerd';
    position: absolute;
    left: 0;
    top: -1.6rem;
    background: var(--color-navy);
    color: #ffffff;
    font-size: 0.7rem;
    font-family: var(--font-body);
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* .cite-btn reuses .permalink-btn's position/opacity/hover-reveal rules
     above (combined selector), it only needs its own copied-state label. */
  .doc__article :global(.cite-btn.is-copied)::after {
    content: 'Citaat gekopieerd';
  }

  .doc__article :global(h3),
  .doc__article :global(h4) {
    margin-top: 2.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.35rem;
  }

  .doc__article :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-collapse: collapse;
    width: 100%;
    margin: 1rem 0;
    font-size: 0.9rem;
  }

  .doc__article :global(th),
  .doc__article :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.4rem 0.6rem;
    text-align: left;
  }

  .doc__article :global(th) {
    background: var(--color-bg-alt);
  }

  @media (max-width: 60rem) {
    .doc {
      grid-template-columns: 1fr;
    }

    .doc__toc {
      position: static;
    }
  }
</style>

<script define:vars={{ abbr }}>
  // Every article in every wet is an h5 with an auto-slugified id
  // (see src/lib/rehype-mkdocs-slugs.mjs), so a permalink button can be
  // injected site-wide here without touching any of the MDX content files.
  document.querySelectorAll('.doc__article h5[id]').forEach((heading) => {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = 'permalink-btn';
    button.setAttribute('aria-label', 'Kopieer link naar dit artikel');
    button.innerHTML =
      '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">' +
      '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>' +
      '<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>' +
      '</svg>';

    button.addEventListener('click', async () => {
      const url = `${location.origin}${location.pathname}#${heading.id}`;
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        // Clipboard API unavailable (e.g. insecure context); the hash
        // below still gets updated so the URL bar reflects the article.
      }
      history.replaceState(null, '', `#${heading.id}`);
      button.classList.add('is-copied');
      setTimeout(() => button.classList.remove('is-copied'), 1500);
    });

    heading.appendChild(button);

    // Only wetgeving documents carry an `abbr` (e.g. "Sr") in their
    // frontmatter, and only headings that actually follow the
    // "Artikel <nr> | <titel>" convention have a number to cite -- both
    // doj/pages content and any oddly-formatted heading silently get no
    // citation button instead of a broken one.
    const articleMatch = heading.textContent.match(/Artikel\s+(\S+)/i);
    if (abbr && articleMatch) {
      const citation = `Art. ${articleMatch[1]} ${abbr}`;
      const citeButton = document.createElement('button');
      citeButton.type = 'button';
      citeButton.className = 'permalink-btn cite-btn';
      citeButton.setAttribute('aria-label', 'Kopieer citaat van dit artikel');
      citeButton.innerHTML =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">' +
        '<path d="M9 18V9a3 3 0 0 1 3-3"></path>' +
        '<path d="M6 12h3v6H6a3 3 0 0 1-3-3v-1a2 2 0 0 1 2-2Z"></path>' +
        '<path d="M18 18V9a3 3 0 0 1 3-3"></path>' +
        '<path d="M15 12h3v6h-3a3 3 0 0 1-3-3v-1a2 2 0 0 1 2-2Z"></path>' +
        '</svg>';

      citeButton.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(citation);
        } catch {
          // Clipboard API unavailable (e.g. insecure context) -- silently
          // skip the confirmation state below rather than error.
        }
        citeButton.classList.add('is-copied');
        setTimeout(() => citeButton.classList.remove('is-copied'), 1500);
      });

      heading.appendChild(citeButton);
    }
  });

  // Article text is authored as a numbered/lettered list per item (see
  // src/lib/remark-unwrap-article-text.mjs), joined into one long logical
  // line per item so the browser can word-wrap it naturally. But a plain
  // wrap always restarts at column 0, so a wrapped "   a. ..." or "1. ..."
  // item loses its marker indent on every line after the first. This gives
  // each line its own CSS hanging indent -- sized to its own leading
  // whitespace + marker -- so wrapped continuation text lines up under the
  // marker's text instead of the left edge, at any viewport width.
  const MARKER_RE = /^(\s*)((?:\d+\.|\d+°|[a-zA-Z]\.|-)\s)/;
  document.querySelectorAll('.doc__article pre.astro-code > code').forEach((code) => {
    // Shiki separates line spans with a literal newline text node; once a
    // line becomes a block box below, that leftover newline would render
    // as its own blank line (still preserved by the block's white-space:
    // pre-wrap), so it has to go first.
    Array.from(code.childNodes).forEach((node) => {
      if (node.nodeType === Node.TEXT_NODE && node.textContent.trim() === '') {
        node.remove();
      }
    });

    code.querySelectorAll(':scope > span.line').forEach((line) => {
      line.style.display = 'block';
      const match = MARKER_RE.exec(line.textContent);
      if (!match) return;
      const width = match[1].length + match[2].length;
      line.style.paddingLeft = `${width}ch`;
      line.style.textIndent = `-${width}ch`;
    });
  });
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pagina niet gevonden" description="Deze pagina bestaat niet of is verplaatst.">
  <div class="error-doc">
    <p class="error-doc__code">404</p>
    <h1>Pagina niet gevonden</h1>
    <p>
      De opgevraagde pagina bestaat niet, is verplaatst of ingetrokken. Controleer de
      adresbalk of gebruik de navigatie hiernaast om verder te gaan.
    </p>
    <div class="error-doc__actions">
      <a href="/" class="error-doc__button">Terug naar de startpagina</a>
    </div>
  </div>
</BaseLayout>

<style>
  .error-doc {
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-gold);
    border-radius: 4px;
    background: var(--color-bg-alt);
    padding: 2.5rem;
    max-width: 34rem;
  }

  .error-doc__code {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-gold-dark);
    margin: 0;
    line-height: 1;
  }

  .error-doc h1 {
    margin: 0.5rem 0 1rem;
  }

  .error-doc p {
    color: var(--color-text-muted);
  }

  .error-doc__actions {
    margin-top: 1.5rem;
  }

  .error-doc__button {
    display: inline-block;
    border-radius: 4px;
    background: var(--color-navy);
    color: #ffffff;
    padding: 0.6rem 1.25rem;
    font-weight: 700;
    text-decoration: none;
  }

  .error-doc__button:hover {
    background: var(--color-navy-light);
    color: #ffffff;
  }
</style>
